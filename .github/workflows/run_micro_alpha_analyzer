name: Run Micro Alpha Analyzer

on:
  # 1. 毎日決まった時間（例: 日本時間 朝9:00 / UTC 0:00）に定期自動実行したい場合
  schedule:
    - cron: '0 0 * * *'
  
  # 2. GitHubの画面からいつでもボタンポチで手動実行したい場合
  workflow_dispatch:

jobs:
  run-analyzer:
    runs-on: ubuntu-latest

    steps:
    - name: Checkout Repository
      uses: actions/checkout@v4

    - name: Set up Python
      uses: actions/setup-python@v5
      with:
        python-version: '3.10'
        cache: 'pip' # 依存ライブラリのキャッシュを有効化して高速化

    - name: Install Dependencies
      run: |
        python -m pip install --upgrade pip
        pip install requests yfinance gspread google-auth beautifulsoup4 google-genai

    - name: Run Script
      env:
        # GitHub Secretsから安全に環境変数を注入
        GCP_SERVICE_ACCOUNT_KEY: ${{ secrets.GCP_SERVICE_ACCOUNT_KEY }}
        GEMINI_API_KEY: ${{ secrets.GEMINI_API_KEY }}
      run: |
        # スクリプト内の SPREADSHEET_ID を環境変数から動的に置換して実行
        python -c "
        with open('micro_alpha_analyzer.py', 'r') as f:
            code = f.read()
        # コード内のプレースホルダーをSecretsの値に書き換える
        code = code.replace('あなたのスプレッドシートID', '${{ secrets.SPREADSHEET_ID }}')
        with open('micro_alpha_analyzer_run.py', 'w') as f:
            f.write(code)
        "
        # 実行
        python micro_alpha_analyzer_run.py
